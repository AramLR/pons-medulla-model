---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import coliculo_s from "@images/coliculo_superior.svg?raw"

export const getStaticPaths = (async () => {
const levels =  await getCollection('levels')
  


return levels.map((level) => {
  
  return {
    params: { id: level.id},
    props: { level }
  }
})

}) satisfies GetStaticPaths;

const { level } = Astro.props
const allSvgs = import.meta.glob("../../img/*.svg",
  {
    query: "?raw",
    import: "default"
  }
)

const svgPath = level.data.svgPath ? `/src/img/${level.data.svgPath}` : null;
console.log("Level ID:", level.id);
console.log("SVG Path from data:", level.data.svgPath);
console.log("Looking for:", svgPath);
console.log("Available keys:", Object.keys(allSvgs));

// Find the matching key dynamically
const svgKey = svgPath ? Object.keys(allSvgs).find(key => key.endsWith(level.data.svgPath)) : null;
console.log("Found key:", svgKey);
const svgContent = svgKey ? await allSvgs[svgKey]() : null;

const sortedStructures = [...level.data.structures].sort((a, b) => {
  if(a.id < b.id){
    return -1;
  } else {
    return 1;
  }
})

console.log(svgPath in allSvgs)

const imageUrl = level.data.imgUrl.src;

console.log(allSvgs)
---

<Layout pageTitle={level.data.name}>
  <div class="w-full px-2 sm:px-4 md:px-8 py-6 sm:py-8">
    <!-- Responsive Card Section -->
    {imageUrl && (
      <>
        <div class="flex justify-center mb-8">
          <div class="card bg-base-100 shadow-xl w-full max-w-5xl lg:card-side">
            <!-- Image Section -->
            <figure class="w-full lg:w-2/5 flex-shrink-0">
              <div class="relative w-full flex items-center justify-center bg-gray-50">
                <img 
                  id="mainImage"
                  src={imageUrl} 
                  alt={level.data.name}
                  class="w-full h-auto cursor-pointer hover:opacity-95 transition-opacity z-0"
                />
                <div class="svg-overlay absolute inset-0 pointer-events-none" set:html={svgContent}></div>
              </div>
            </figure>

            <!-- Card Body Section -->
            <div class="card-body w-full lg:w-3/5 justify-between">
              <div>
                <h2 id="cardTitle" class="card-title text-2xl sm:text-3xl text-gray-900">
                  {level.data.name}
                </h2>
                <p class="text-gray-600 text-sm sm:text-base mt-2">
                  Selecciona una estructura en la imagen
                </p>
              </div>

              <!-- Expand Button -->
              <div class="card-actions justify-start mt-4">
                <button 
                  id="expandBtn"
                  class="btn btn-primary flex items-center gap-2"
                  aria-label="Expand image"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M7 17h3q.425 0 .713.288T11 18t-.288.713T10 19H6q-.425 0-.712-.288T5 18v-4q0-.425.288-.712T6 13t.713.288T7 14zM17 7h-3q-.425 0-.712-.288T13 6t.288-.712T14 5h4q.425 0 .713.288T19 6v4q0 .425-.288.713T18 11t-.712-.288T17 10z"/></svg>
                  Ampliar
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Modal -->
        <div 
          id="imageModal"
          class="hidden fixed inset-0 bg-black bg-opacity-90 z-50 flex items-center justify-center p-4 cursor-pointer"
        >
          <button
            id="closeBtn"
            class="absolute top-4 right-4 text-white hover:bg-gray-700 rounded-full p-2 transition-colors duration-200"
            aria-label="Close modal"
          >
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
          <img 
            id="modalImage"
            src={imageUrl}
            alt={level.data.name}
            class="max-w-5xl max-h-[85vh] w-auto h-auto object-contain rounded-lg shadow-2xl"
          />
        </div>
      </>
    )}
    
    <!-- Structures List Section -->
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2 sm:mb-3">Estructuras</h2>
      <p class="text-gray-600 text-sm sm:text-base mb-6 sm:mb-8">Componentes anatómicos identificados</p>
      <div class="space-y-2 sm:space-y-3">
        {sortedStructures.map((structure, index) => (
          <div class="flex items-start gap-3 sm:gap-4 p-3 sm:p-4 rounded-lg bg-white border border-gray-200 hover:border-uaslp hover:shadow-md transition-all duration-200 group cursor-pointer">
            <span class="shrink-0 inline-flex items-center justify-center w-7 h-7 sm:w-8 sm:h-8 bg-uaslp text-white rounded-full text-xs sm:text-sm font-bold group-hover:scale-110 transition-transform duration-200">
              {structure.id}
            </span>
            <span class="pt-1 sm:pt-1.5 text-gray-800 text-sm sm:text-base font-medium group-hover:text-gray-900 transition-colors duration-200">
              {structure.name}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <script>
    const modal = document.getElementById('imageModal');
    const expandBtn = document.getElementById('expandBtn');
    const closeBtn = document.getElementById('closeBtn');
    const mainImage = document.getElementById('mainImage');
    const cardTitle = document.getElementById('cardTitle');

    expandBtn?.addEventListener('click', () => {
      modal?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    });

    closeBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      modal?.classList.add('hidden');
      document.body.style.overflow = 'auto';
    });

    modal?.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.add('hidden');
        document.body.style.overflow = 'auto';
      }
    });

    const structures = document.querySelectorAll(
  ".svg-overlay path, .svg-overlay ellipse, .svg-overlay rect"
);

let selectedElement = null;

function formatName(id) {
  return id
    .replaceAll("_", " ")
    .replace(/\b\w/g, (char) => char.toUpperCase());
}

structures.forEach((el) => {
  el.addEventListener("click", () => {
    // Remove previous selection
    if (selectedElement) {
      selectedElement.classList.remove("selected");
    }

    // Add current selection
    el.classList.add("selected");
    selectedElement = el;

    // Human-readable name
    const readableName = formatName(el.id);

    // Update card title
    if (cardTitle) {
      cardTitle.textContent = readableName;
    }

    console.log("Selected:", readableName);
  });
});
  </script>

<style is:global>
.svg-overlay path,
.svg-overlay ellipse,
.svg-overlay rect {
  fill: transparent !important;
  stroke: transparent !important;
  cursor: pointer;
  pointer-events: auto;
  transition: fill 0.2s ease, stroke 0.2s ease;
}
.svg-overlay .selected {
  fill: rgba(34, 197, 94, 0.35) !important;
  stroke: rgb(34, 197, 94) !important;
  stroke-width: 2;
}
</style>

</Layout>